              "raw": "{{baseUrl}}/stories?limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "stories"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Story By Id",
          "request": {
            "method": "GET",
