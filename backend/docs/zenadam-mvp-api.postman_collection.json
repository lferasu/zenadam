                "{{baseUrl}}"
              ],
              "path": [
                "stories",
                "inspection"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "page",
                  "value": "1"
                }
              ]
            }
          }
        },
        {
          "name": "Inspection Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/stories/inspection/{{storyId}}?debug=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "stories",
                "inspection",
                "{{storyId}}"
              ],
              "query": [
                {
                  "key": "debug",
                  "value": "true"
                }
              ]
            }
          }
        }
      ]
