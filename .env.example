# Runtime
NODE_ENV=development
PORT=3000
API_BASE_PATH=/api/v1
LOG_LEVEL=info
STORY_MAX_AGE_DAYS=0

# Database
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=zenadam_dev

# AI providers / models
AI_API_KEY=<your_ai_provider_key>
AI_TRANSLATION_MODEL=<translation_model_name>
AI_SUMMARY_MODEL=<summarization_model_name>
AI_EMBEDDING_MODEL=<embedding_model_name>
OPENAI_API_KEY=<your_openai_api_key>
ZENADAM_EMBEDDING_MODEL=text-embedding-3-large
# ISO language code for normalized user-facing fields (e.g., am, en, fr)
ZENADAM_TARGET_LANGUAGE=am
ZENADAM_ENABLE_NORMALIZATION=true
ZENADAM_ENABLE_STORY_SUMMARY_REFRESH=true
ZENADAM_NORMALIZATION_BATCH_LIMIT=100

# Incremental clustering
VECTOR_SEARCH_ENABLED=true
VECTOR_SEARCH_INDEX_NAME=normalized_item_embedding_index
VECTOR_NUM_CANDIDATES=100
CANDIDATE_WINDOW_HOURS=72
CANDIDATE_FORWARD_WINDOW_HOURS=6
MAX_CANDIDATE_ARTICLES=200
MAX_NEAREST_ARTICLES=10
SIMILARITY_STRONG_THRESHOLD=0.72
SIMILARITY_BORDERLINE_THRESHOLD=0.70

# Queue + auth
QUEUE_BACKEND=mongodb
JWT_SECRET=<strong_secret_if_auth_enabled>
ADMIN_BASIC_AUTH_USER=admin
ADMIN_BASIC_AUTH_PASS=change_me
